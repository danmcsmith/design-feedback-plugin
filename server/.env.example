# Copy this file to server/.env and fill in your values

# Notion integration token (from notion.so/my-integrations)
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ID of the Notion page to create project databases under
# Extract from the page URL: notion.so/Page-Title-{THIS_PART}
NOTION_PARENT_PAGE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Public URL of this server (used to construct screenshot URLs returned to clients)
SERVER_URL=http://localhost:3001

# Postgres connection string
DATABASE_URL=postgresql://localhost:5432/design_feedback

# Comma-separated list of allowed origins, or * for all
CORS_ORIGINS=*

# Port to listen on (default: 3001)
PORT=3001
